<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Carta para PEP</title>

<style>

body{
margin:0;
font-family:Arial;
color:white;
text-align:center;
height:100vh;
overflow:hidden;
background:linear-gradient(#0a0a0a,#1a1a1a);
}

#ceu{
position:fixed;
width:100%;
height:100%;
background:url("https://i.imgur.com/9QZ7Z6S.png");
background-size:cover;
opacity:0.25;
z-index:-1;
animation:nuvens 60s linear infinite;
}

@keyframes nuvens{
0%{background-position:0 0}
100%{background-position:1000px 0}
}

h1{
color:#ff4444;
font-size:40px;
}

img{
width:220px;
border-radius:12px;
margin:12px;
}

button{
font-size:20px;
padding:10px 22px;
margin:10px;
border-radius:10px;
border:none;
cursor:pointer;
}

#sim{
background:black;
color:white;
border:2px solid white;
}

#nao{
background:red;
color:white;
position:absolute;
left:50%;
top:65%;
transform:translate(-50%,-50%);
}

.numero67{
position:absolute;
font-size:48px;
color:red;
animation:cair 6s linear forwards;
}

@keyframes cair{
0%{transform:translateY(-100px)}
100%{transform:translateY(110vh)}
}

.piscar{
animation:piscando 0.3s infinite;
}

@keyframes piscando{
0%{opacity:1}
50%{opacity:0.1}
100%{opacity:1}
}

.treme{
animation:tremer 0.15s infinite;
}

@keyframes tremer{
0%{transform:translate(0,0)}
25%{transform:translate(6px,-6px)}
50%{transform:translate(-6px,6px)}
75%{transform:translate(6px,6px)}
100%{transform:translate(-6px,-6px)}
}

</style>
</head>

<body>

<div id="ceu"></div>

<h1>⚠️ ALERTA DO SISTEMA ⚠️</h1>

<p id="texto">Sistema detectou atividade suspeita</p>

<img id="img" src="inicio.jpg">

<br>

<button id="sim">SIM</button>
<button id="nao">NÃO</button>

<p id="contador"></p>
<p id="radar"></p>

<audio id="boom">
<source src="https://www.myinstants.com/media/sounds/vine-boom.mp3">
</audio>

<audio id="risada">
<source src="https://www.myinstants.com/media/sounds/evil-laugh.mp3">
</audio>

<audio id="dramatico">
<source src="https://www.myinstants.com/media/sounds/movie_1.mp3">
</audio>

<script>

let tentativas=0
let distancia=10

const nao=document.getElementById("nao")
const texto=document.getElementById("texto")
const contador=document.getElementById("contador")
const radar=document.getElementById("radar")
const img=document.getElementById("img")

function fugir(){

tentativas++

document.getElementById("boom").play()

contador.innerHTML="tentativas de apertar NÃO: "+tentativas

if(tentativas==1){
texto.innerHTML="🤨 tentando apertar NÃO?"
img.src="resenha.jpg"
}

if(tentativas==2){
texto.innerHTML="⚠️ tentativa de fuga detectada"
}

if(tentativas==3){
texto.innerHTML="aceita logo carai"
}

if(tentativas==4){
texto.innerHTML="🚨 ativando radar"
document.body.classList.add("treme")
iniciarRadar()
}

if(tentativas==5){
texto.innerHTML="💀 modo meme ativado"
chuvaMemes()
numeros67()
}

let x=Math.random()*window.innerWidth
let y=Math.random()*window.innerHeight

nao.style.left=x+"px"
nao.style.top=y+"px"

}

nao.addEventListener("mouseover", fugir)

function iniciarRadar(){

let intervalo=setInterval(()=>{

distancia--

radar.innerHTML="🚨 fiscalização chegando: "+distancia+" km"

if(distancia<=0){

radar.innerHTML="⚠️ inspeção iniciada"

setTimeout(()=>{
document.body.classList.remove("treme")
},4000)

clearInterval(intervalo)

}

},1500)

}

function chuvaMemes(){

setInterval(()=>{

let img=document.createElement("img")

img.src=Math.random()>0.5?"inicio.jpg":"resenha.jpg"

img.style.position="absolute"
img.style.width="120px"
img.style.left=Math.random()*100+"vw"

document.body.appendChild(img)

setTimeout(()=>img.remove(),6000)

},800)

}

function numeros67(){

setInterval(()=>{

let n=document.createElement("div")

n.innerHTML="67"

n.className="numero67"

n.style.left=Math.random()*100+"vw"

document.body.appendChild(n)

setTimeout(()=>n.remove(),6000)

},600)

}

document.getElementById("sim").onclick=function(){

document.getElementById("dramatico").play()

document.body.innerHTML=`

<h1>😳 você apertou SIM</h1>

<p>analisando decisão...</p>

<img src="inicio.jpg">

`

setTimeout(()=>{

document.body.innerHTML=`

<h1>⏳ verificando compatibilidade...</h1>

<p>processando dados...</p>

`

},4000)

setTimeout(()=>{

document.body.innerHTML=`

<h1>⚠️ averiguando possível resenha</h1>

<img src="resenha.jpg">

<p>talvez eu aceite esse sonho na GPT-8</p>

<button onclick="numeroProibido()">entrar no número proibido</button>

`

},9000)

}

function numeroProibido(){

document.body.innerHTML=`

<h1 class="piscar">⚠️ NÚMERO PROIBIDO DETECTADO</h1>

<p>executando modo meme...</p>

<img src="inicio.jpg">

`

setTimeout(()=>{

for(let i=0;i<40;i++){

let n=document.createElement("div")

n.innerHTML="67"

n.className="numero67"

n.style.left=Math.random()*100+"vw"

document.body.appendChild(n)

}

document.getElementById("risada").play()

},2000)

}

</script>

</body>
</html>
